# VibeFeed iOS — no third-party pods.
#
# The Appodeal/AdMob ad SDK was removed 2026-07-24 to resolve an App Review
# AppTrackingTransparency finding: VibeFeed ships with no ads and no tracking, so
# the binary must not link any framework that references AppTrackingTransparency.
# If ads are reintroduced later, re-add the Appodeal pods + their spec sources here.

platform :ios, '17.0'

source 'https://cdn.cocoapods.org/'

install! 'cocoapods', :deterministic_uuids => false

use_frameworks!

target 'VibeFeed' do
  # No pods. Intentionally empty.
end

# Keep the (empty) pods project on iOS 17 and quiet simulator signing.
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
end
