# VibeFeed iOS — Appodeal SDK 4.2.0 with Google AdMob + BidMachine mediation.
#
# The owner's Appodeal app (782028) uses AdMob-managed mediation; Appodeal's
# dashboard selects the actual ad units at runtime (no ad-unit ids hardcoded here).
# BidMachine (Appodeal's own programmatic demand, no extra account) is added as a
# SECOND demand source so an MREC no-fill/refresh from AdMob can be back-filled —
# a single-network fleet was leaving the sponsored slot empty ("ads disappear").
#
# Build after `pod install` with:
#   cd ios && xcodebuild -workspace VibeFeed.xcworkspace -scheme VibeFeed \
#     -sdk iphonesimulator -configuration Debug CODE_SIGNING_ALLOWED=NO build

platform :ios, '17.0'

# Appodeal SDK + adapters live in Appodeal's own spec repo; the AdMob adapter
# pulls Bidon (Appodeal's bidding layer) from the Bidon spec repo; everything
# else (Google-Mobile-Ads-SDK, Protobuf) comes from the CocoaPods CDN.
source 'https://github.com/appodeal/CocoaPods.git'
source 'https://github.com/bidon-io/CocoaPods-Specs.git'
source 'https://cdn.cocoapods.org/'

install! 'cocoapods', :deterministic_uuids => false

use_frameworks!

target 'VibeFeed' do
  pod 'Appodeal', '4.2.0'
  pod 'AppodealGoogleAdMobAdapter', '12.13.0.0'
  pod 'AppodealBidMachineAdapter', '3.7.1.0'
end

# Keep the pods on iOS 17 and strip bitcode/signing noise for simulator builds.
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      # Protobuf (pulled in by Google-Mobile-Ads) uses double-quoted includes in
      # its framework headers; newer Xcode's framework-module verifier treats that
      # as an error on device builds. Silence the pedantic pod-header check.
      config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
    end
  end
end
